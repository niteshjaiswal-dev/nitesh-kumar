RewriteEngine On

# Library slug URL
RewriteRule ^library/([a-zA-Z0-9-]+)/?$ library.html?slug=$1 [L,QSA]

# Existing rule to load .html automatically
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Custom 404 page
ErrorDocument 404 /404.html